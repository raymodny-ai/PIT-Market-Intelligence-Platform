# =============================================================================
# PIT Market Intelligence — Web (Next.js) image
# Multi-stage build: deps → build → runtime.
# Targets Node 20 (matches Next.js 14.2 LTS), exposes 3000 by default.
#
# Build:    docker build -f docker/Dockerfile.web -t pit-market/web:dev .
# Run:      docker run --rm -p 8701:3000 \
#             -e NEXT_PUBLIC_API_BASE=http://127.0.0.1:8700 \
#             pit-market/web:dev
# =============================================================================

# ---- Stage 1: install deps ----
FROM node:22-bookworm-slim AS deps
WORKDIR /opt/pit/web

# Copy package files only. We deliberately use `npm install` (not `npm ci`)
# because upstream's package.json bumps (@testing-library/*, jsdom, vitest,
# plotly.js 2.35.3, etc.) are not yet reflected in package-lock.json. Using
# `npm install` regenerates the lockfile in the build cache so this Dockerfile
# is resilient to upstream lockfile drift. The `--legacy-peer-deps` flag
# silences the ag-grid vs React peer dep warnings.
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install --legacy-peer-deps --no-audit --no-fund

# ---- Stage 2: build ----
FROM node:22-bookworm-slim AS build
WORKDIR /opt/pit/web

# NEXT_PUBLIC_API_BASE is inlined into the bundle at build time.
# Default to the host-side FastAPI port (8700 on local NAS) so that the
# rewrite proxy target is correct without any runtime env wiring.
ARG NEXT_PUBLIC_API_BASE=http://127.0.0.1:8700
ENV NEXT_PUBLIC_API_BASE=${NEXT_PUBLIC_API_BASE} \
    NEXT_TELEMETRY_DISABLED=1

COPY --from=deps /opt/pit/web/node_modules ./node_modules
COPY frontend ./

RUN npm run build

# ---- Stage 3: runtime ----
FROM node:22-bookworm-slim AS runtime
WORKDIR /opt/pit/web

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# curl is required by the HEALTHCHECK below (and useful for debugging).
# Keep this layer slim by combining with the useradd below.
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

# Non-root user — match numeric uid for NAS volume compatibility.
RUN groupadd --system --gid 1001 pit \
    && useradd --system --uid 1001 --gid pit --home /opt/pit/web pit

# Bring only the production node_modules + build artifacts.
COPY --from=build --chown=pit:pit /opt/pit/web/node_modules ./node_modules
COPY --from=build --chown=pit:pit /opt/pit/web/.next ./.next
COPY --from=build --chown=pit:pit /opt/pit/web/public ./public
COPY --from=build --chown=pit:pit /opt/pit/web/package.json ./package.json
COPY --from=build --chown=pit:pit /opt/pit/web/next.config.mjs ./next.config.mjs

USER pit
EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -fsS http://127.0.0.1:3000/ || exit 1

CMD ["npm", "run", "start"]
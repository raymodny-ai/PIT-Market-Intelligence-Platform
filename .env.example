# =============================================================================
# PIT Market Intelligence Platform — Environment Variables (EXAMPLE)
# Copy to .env (NOT committed) and fill real values. NEVER commit .env.
# =============================================================================

# ----- Runtime -----
PIT_ENV=development                    # development | staging | production
PIT_LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
PIT_CONFIG_DIR=./config

# ----- Data sources (P0) -----
# Yahoo Finance: rate-limited public API, no key required
YFINANCE_RATE_LIMIT_PER_SEC=1.0
YFINANCE_TIMEOUT_SEC=30

# FRED / ALFRED: required for macro data
FRED_API_KEY=replace_with_real_key      # https://fred.stlouisfed.org/docs/api/api_key.html
FRED_BASE_URL=https://api.stlouisfed.org
ALFRED_REQUIRED=true                    # Refuse to run if false (PIT discipline #8)

# CFTC COT: public data, no key required
CFTC_BASE_URL=https://www.cftc.gov
CFTC_TIMEOUT_SEC=60

# FINRA Reg SHO: public data, no key required (be respectful)
FINRA_BASE_URL=https://api.finra.org
FINRA_RATE_LIMIT_PER_SEC=0.5

# ----- Data sources (P1) -----
# SEC EDGAR: User-Agent required
SEC_EDGAR_USER_AGENT=PIT Market Intelligence research@example.com
SEC_EDGAR_RATE_LIMIT_PER_SEC=10         # SEC allows 10 req/s with proper UA

# ETF issuer websites (State Street, BlackRock, etc.)
ETF_SCRAPER_USER_AGENT=Mozilla/5.0 (research)

# ----- LLM providers -----
OPENAI_API_KEY=replace_with_real_key
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=                          # optional
LOCAL_LLM_BASE_URL=http://localhost:11434  # Ollama default

# ----- Storage -----
DUCKDB_PATH=./data/pit.duckdb
RAW_DATA_DIR=./data/raw
SILVER_DATA_DIR=./data/silver
GOLD_DATA_DIR=./data/gold
METADATA_DIR=./data/metadata
REPORTS_DIR=./data/reports

# ----- Cache (Phase 2: in-process; Phase 5: Redis) -----
CACHE_BACKEND=cachetools                # cachetools | redis
CACHE_TTL_SEC=900                       # 15 min
REDIS_URL=redis://localhost:6379/0      # used when CACHE_BACKEND=redis

# ----- Dagster -----
DAGSTER_HOME=./data/dagster_home
DAGSTER_PORT=3000
